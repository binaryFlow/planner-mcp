# Copy to .env and fill in. Do NOT commit your real .env.

# Which auth backend to use: "device" (default, recommended) or "browser".
AUTH_METHOD=device

# Your Microsoft Entra tenant ID (GUID). "organizations" works for most work accounts.
TENANT_ID=organizations

# --- device-code auth (AUTH_METHOD=device) ---
# Application (client) ID of YOUR OWN Azure app registration (public client with
# delegated User.Read + Tasks.ReadWrite). Required for device-code auth.
CLIENT_ID=

# --- browser fallback (AUTH_METHOD=browser) ---
# No CLIENT_ID needed; it defaults to the Graph Explorer client. See README for
# the important caveats before using this method.

# Optional: space-separated delegated Graph scopes (default: User.Read Tasks.ReadWrite)
# GRAPH_SCOPES=User.Read Tasks.ReadWrite

# Optional: pre-fill the sign-in account.
# GRAPH_LOGIN_HINT=you@example.com
